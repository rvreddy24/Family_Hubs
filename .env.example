# =============================================
# FamilyHubs.in — Environment Configuration
# =============================================

# Gemini AI API Key (optional, for AI-powered features)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Application URL (used for OAuth callbacks and self-referential links)
APP_URL="http://localhost:3000"

# Socket.io / Express Server
VITE_SOCKET_URL="http://localhost:3001"
PORT=3001
CLIENT_URL="http://localhost:3000"

# Production Mode
# NODE_ENV="production"

# Supabase (future integration)
# VITE_SUPABASE_URL="https://your-project.supabase.co"
# VITE_SUPABASE_ANON_KEY="your-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
