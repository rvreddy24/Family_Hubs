# Browser (Vite)
# Socket.io target when not using Vite proxy (set in production builds)
VITE_SOCKET_URL="http://localhost:3001"

# Optional: Supabase auth in the browser (use project base URL, NOT .../rest/v1/)
# VITE_SUPABASE_URL="https://your-project-id.supabase.co"
# VITE_SUPABASE_ANON_KEY="your-anon-key"

# API server (Node)
PORT=3001
CLIENT_URL="http://localhost:3000"
# Comma-separated extra origins, e.g. a LAN URL for a phone: http://192.168.1.10:3000
# ALLOWED_ORIGINS="http://192.168.1.10:3000"

# Optional: persist tasks/hubs snapshot (run supabase/migrations in your project)
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# When Supabase is set, require valid JWT on socket (optional)
# STRICT_SOCKET_AUTH=1

# Optional: payments (stubs in server/routes/payments.ts)
# RAZORPAY_KEY_ID=
# STRIPE_PUBLISHABLE_KEY=

# Gemini (optional features)
# GEMINI_API_KEY=

# App URL (links, callbacks)
APP_URL="http://localhost:3000"

# Android provider app: copy values into android/provider/local.properties
#   SOCKET_URL=http://10.0.2.2:3001
#   SUPABASE_URL=...
#   SUPABASE_ANON_KEY=...
#   HUB_ID=hub_mgl
# Emulator: use 10.0.2.2 to reach the host; physical device: use your PC's LAN IP.
